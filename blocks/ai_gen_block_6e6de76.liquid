{% doc %}
  @prompt
    Create (Performance Guarantee, 14-day return policy) panner, set mobile condetions
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-guarantee-banner-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-guarantee-banner__container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.item_spacing }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    flex-wrap: wrap;
  }

  .ai-guarantee-banner__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-guarantee-banner__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-guarantee-banner__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-guarantee-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    margin: 0;
  }

  .ai-guarantee-banner__divider-{{ ai_gen_id }} {
    width: 1px;
    height: {{ block.settings.icon_size }}px;
    background-color: {{ block.settings.divider_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-guarantee-banner-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-guarantee-banner__container-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'column' %}
        flex-direction: column;
      {% else %}
        flex-direction: row;
      {% endif %}
      gap: {{ block.settings.mobile_item_spacing }}px;
      padding: {{ block.settings.mobile_padding_vertical }}px {{ block.settings.mobile_padding_horizontal }}px;
    }

    .ai-guarantee-banner__icon-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_icon_size }}px;
      height: {{ block.settings.mobile_icon_size }}px;
    }

    .ai-guarantee-banner__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }

    .ai-guarantee-banner__divider-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'column' %}
        display: none;
      {% else %}
        height: {{ block.settings.mobile_icon_size }}px;
      {% endif %}
    }
  }
{% endstyle %}

<guarantee-banner-{{ ai_gen_id }}
  class="ai-guarantee-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-guarantee-banner__container-{{ ai_gen_id }}">
    {% if block.settings.show_performance_guarantee %}
      <div class="ai-guarantee-banner__item-{{ ai_gen_id }}">
        <div class="ai-guarantee-banner__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="M9 12l2 2 4-4"></path>
          </svg>
        </div>
        <p class="ai-guarantee-banner__text-{{ ai_gen_id }}">{{ block.settings.performance_text }}</p>
      </div>

      {% if block.settings.show_return_policy %}
        <div class="ai-guarantee-banner__divider-{{ ai_gen_id }}"></div>
      {% endif %}
    {% endif %}

    {% if block.settings.show_return_policy %}
      <div class="ai-guarantee-banner__item-{{ ai_gen_id }}">
        <div class="ai-guarantee-banner__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"></polyline>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
          </svg>
        </div>
        <p class="ai-guarantee-banner__text-{{ ai_gen_id }}">{{ block.settings.return_text }}</p>
      </div>
    {% endif %}
  </div>
</guarantee-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class GuaranteeBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('guarantee-banner-{{ ai_gen_id }}', GuaranteeBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Guarantee banner",
  "settings": [
    {
      "type": "header",
      "content": "Performance guarantee"
    },
    {
      "type": "checkbox",
      "id": "show_performance_guarantee",
      "label": "Show performance guarantee",
      "default": true
    },
    {
      "type": "text",
      "id": "performance_text",
      "label": "Performance text",
      "default": "Performance Guarantee"
    },
    {
      "type": "header",
      "content": "Return policy"
    },
    {
      "type": "checkbox",
      "id": "show_return_policy",
      "label": "Show return policy",
      "default": true
    },
    {
      "type": "text",
      "id": "return_text",
      "label": "Return policy text",
      "default": "14-Day Return Policy"
    },
    {
      "type": "header",
      "content": "Desktop style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#350b16"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 8,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile style"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Layout",
      "options": [
        {
          "value": "row",
          "label": "Row"
        },
        {
          "value": "column",
          "label": "Column"
        }
      ],
      "default": "column"
    },
    {
      "type": "range",
      "id": "mobile_icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "label": "Text size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "mobile_padding_horizontal",
      "label": "Horizontal padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_item_spacing",
      "label": "Item spacing",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Guarantee banner"
    }
  ]
}
{% endschema %}
