{% doc %}
  @prompt
    Create an animated performance guarantee marquee banner section that pins to the top of every page above the header. The banner should have a solid emerald green background (#16a34a) with high-contrast white text and icons. Include smooth infinite horizontal scrolling animation that pauses on hover, with customizable scroll speed via a range slider. Add inline SVG icons (checkmark, shield, star, lightning bolt, truck, heart) before each message, and decorative separator symbols between items in mint green. Make it fully customizable through the Theme Editor with controls for: background color, text color, icon color, separator color, font size, font weight, vertical padding, icon size, scroll speed, separator symbol text, and unlimited "Guarantee Item" blocks (each with message text, icon picker, and show/hide icon toggle). Include a subtle bottom border and soft green glow shadow. Use uppercase, wide letter-spaced typography with a modern sans-serif font. Ensure it's a valid Shopify OS 2.0 section with clean schema JSON, CSS-only animation (no JavaScript), ARIA accessibility attributes (role="marquee" and aria-label), and include presets with 5 pre-filled blocks so it works immediately on install.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-guarantee-marquee-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 4px 12px rgba(22, 163, 74, 0.15);
    overflow: hidden;
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-guarantee-marquee-wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-guarantee-marquee-{{ ai_gen_id }}:hover .ai-guarantee-marquee-wrapper-{{ ai_gen_id }} {
    animation-play-state: paused;
  }

  .ai-guarantee-marquee-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 40px;
    white-space: nowrap;
    padding-right: 40px;
  }

  .ai-guarantee-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }

  .ai-guarantee-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-guarantee-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-guarantee-separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-guarantee-item-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.85);
    }

    .ai-guarantee-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.85);
      height: calc({{ block.settings.icon_size }}px * 0.85);
    }
  }
{% endstyle %}

