{{ 'cro-enhancements.css' | asset_url | stylesheet_tag }}

<section class="teeb-testimonials" id="teeb-testimonials-{{ section.id }}">
  <div class="page-width">
    <div class="teeb-testimonials__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="teeb-testimonials__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.arabic_heading != blank -%}
        <p class="teeb-testimonials__arabic-heading teeb-arabic">{{ section.settings.arabic_heading }}</p>
      {%- endif -%}
      <div class="teeb-testimonials__heading-line"></div>
    </div>

    <div class="teeb-testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="teeb-testimonials__card" {{ block.shopify_attributes }}>
          <div class="teeb-testimonials__stars" aria-label="{{ block.settings.stars }} out of 5 stars">
            {%- assign star_count = block.settings.stars | plus: 0 -%}
            {%- for i in (1..5) -%}
              <span class="teeb-testimonials__star{% if i <= star_count %} teeb-testimonials__star--filled{% endif %}" aria-hidden="true">★</span>
            {%- endfor -%}
          </div>

          {%- if block.settings.quote != blank -%}
            <blockquote class="teeb-testimonials__quote">
              <span class="teeb-testimonials__quote-mark" aria-hidden="true">"</span>
              {{ block.settings.quote }}
              <span class="teeb-testimonials__quote-mark teeb-testimonials__quote-mark--close" aria-hidden="true">"</span>
            </blockquote>
          {%- endif -%}

          <footer class="teeb-testimonials__attribution">
            <span class="teeb-testimonials__name">{{ block.settings.name }}</span>
            {%- if block.settings.location != blank -%}
              <span class="teeb-testimonials__location">{{ block.settings.location }}</span>
            {%- endif -%}
            {%- if block.settings.product != blank -%}
              <span class="teeb-testimonials__product">— {{ block.settings.product }}</span>
            {%- endif -%}
          </footer>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  /* Dark contrast section — one dark stripe on the ivory page */
  .teeb-testimonials {
    background-color: var(--teeb-ink);
    padding: 8rem 0;
    position: relative;
  }

  /* Subtle gold top border */
  .teeb-testimonials::before {
    content: '';
    display: block;
    height: 1px;
    background: var(--teeb-gold-line);
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
  }

  .teeb-testimonials__header {
    text-align: center;
    margin-bottom: 5.6rem;
  }

  .teeb-testimonials__heading {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    color: var(--teeb-white);
    margin: 0 0 0.6rem;
    font-weight: 400;
  }

  .teeb-testimonials__arabic-heading {
    font-family: 'Noto Naskh Arabic', serif;
    font-size: 1.8rem;
    color: var(--teeb-gold);
    direction: rtl;
    margin: 0 0 2.4rem;
  }

  .teeb-testimonials__heading-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(240,196,23,0.6), transparent);
    width: 40%;
    max-width: 300px;
    margin: 0 auto;
    position: relative;
  }

  .teeb-testimonials__heading-line::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(45deg);
    width: 8px;
    height: 8px;
    border: 1px solid rgba(240,196,23,0.6);
    background: var(--teeb-ink);
  }

  .teeb-testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
  }

  @media (min-width: 750px) {
    .teeb-testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.4rem;
    }
  }

  .teeb-testimonials__card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(184, 146, 46, 0.2);
    padding: 3.2rem;
    position: relative;
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .teeb-testimonials__card:hover {
    border-color: rgba(184, 146, 46, 0.45);
    background: rgba(255, 255, 255, 0.06);
  }

  /* Gold corner frame on each card */
  .teeb-testimonials__card::before,
  .teeb-testimonials__card::after {
    content: '';
    position: absolute;
    width: 40px;
    height: 40px;
    border-color: rgba(184, 146, 46, 0.35);
    border-style: solid;
    pointer-events: none;
  }

  .teeb-testimonials__card::before {
    top: 8px;
    left: 8px;
    border-width: 1px 0 0 1px;
  }

  .teeb-testimonials__card::after {
    bottom: 8px;
    right: 8px;
    border-width: 0 1px 1px 0;
  }

  .teeb-testimonials__stars {
    display: flex;
    gap: 0.3rem;
    margin-bottom: 1.8rem;
  }

  .teeb-testimonials__star {
    font-size: 1.6rem;
    color: rgba(240, 196, 23, 0.25);
  }

  .teeb-testimonials__star--filled {
    color: var(--teeb-gold);
  }

  .teeb-testimonials__quote {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.7rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.65;
    margin: 0 0 2.4rem;
    position: relative;
  }

  .teeb-testimonials__quote-mark {
    font-family: 'Playfair Display', serif;
    font-size: 4rem;
    color: rgba(240, 196, 23, 0.3);
    line-height: 0;
    vertical-align: -1.2rem;
  }

  .teeb-testimonials__quote-mark--close {
    vertical-align: -1.8rem;
  }

  .teeb-testimonials__attribution {
    border-top: 1px solid rgba(184, 146, 46, 0.2);
    padding-top: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .teeb-testimonials__name {
    font-family: 'Open Sans', sans-serif;
    font-weight: 600;
    font-size: 1.3rem;
    color: var(--teeb-gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .teeb-testimonials__location {
    font-family: 'Open Sans', sans-serif;
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .teeb-testimonials__product {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.2rem;
    color: rgba(240, 196, 23, 0.6);
  }
</style>

{% schema %}
{
  "name": "Teeb — Testimonials",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "arabic_heading",
      "label": "Arabic heading",
      "default": "ماذا يقول عملاؤنا"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "The longevity is unreal. I sprayed it in the morning and my colleagues were still commenting on it at 9pm."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Ahmed K."
        },
        {
          "type": "text",
          "id": "location",
          "label": "City",
          "default": "Cairo"
        },
        {
          "type": "text",
          "id": "product",
          "label": "Product (optional)",
          "default": "Ighwa"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Teeb — Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "stars": 5,
            "quote": "The longevity is unreal. I sprayed it in the morning and my colleagues were still commenting on it at 9pm.",
            "name": "Ahmed K.",
            "location": "Cairo",
            "product": "Ighwa"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "stars": 5,
            "quote": "Finally a local brand that doesn't feel local. Serr is mysterious and fresh — I get asked about it every time.",
            "name": "Nour M.",
            "location": "Alexandria",
            "product": "Serr"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "stars": 5,
            "quote": "Bought Thelal for my husband and he refuses to wear anything else now. The packaging is also stunning.",
            "name": "Sara H.",
            "location": "Cairo",
            "product": "Thelal"
          }
        }
      ]
    }
  ]
}
{% endschema %}
