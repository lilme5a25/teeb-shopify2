    },
    "glassBottle": {
      "label": "Luxury glass bottle fill",
      "css": "linear-gradient(135deg, rgba(240,196,23,0.12) 0%, rgba(255,255,255,0.05) 15%, rgba(53,11,22,0.75) 40%, rgba(20,5,10,0.85) 65%, rgba(240,196,23,0.08) 100%)",
      "use": "Bottle body illustration"
    },
    "glowOrb": {
      "label": "Ambient glow behind hero element",
      "css": "radial-gradient(circle, rgba(53,11,22,0.8) 0%, rgba(240,196,23,0.04) 40%, transparent 70%)",
      "use": "Background aura behind bottles or product shots"
