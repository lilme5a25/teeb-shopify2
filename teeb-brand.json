  "gradients": {
    "backgroundBase": {
      "label": "Main background gradient",
      "css": "radial-gradient(ellipse 60% 60% at 50% 30%, #350b16 0%, transparent 70%), radial-gradient(ellipse 40% 40% at 80% 80%, #1a0509 0%, transparent 60%), #000000",
      "use": "Primary ad and page backgrounds"
