    },
    "goldVertical": {
      "label": "Vertical accent line",
      "css": "linear-gradient(180deg, transparent, rgba(240,196,23,0.2), transparent)",
      "use": "Side decorative lines"
    },
    "goldMetallic": {
      "label": "Metallic gold surface",
      "css": "linear-gradient(180deg, #f5d24a 0%, #b8922e 60%, #8a6d0a 100%)",
      "use": "Bottle caps, metallic elements, premium buttons"
    },
    "goldBase": {
      "label": "Bottle base gradient",
      "css": "linear-gradient(90deg, rgba(240,196,23,0.1), rgba(240,196,23,0.5), rgba(240,196,23,0.1))",
