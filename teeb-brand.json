    },
    "goldLine": {
      "label": "Horizontal gold rule",
      "css": "linear-gradient(90deg, transparent, #f0c417, transparent)",
      "use": "Dividers, section separators"
    },
    "goldLineFaded": {
      "label": "Soft gold rule",
      "css": "linear-gradient(90deg, transparent, rgba(240,196,23,0.5), transparent)",
